# Required for SEC EDGAR (fair access policy): your real email
SEC_CONTACT_EMAIL=you@example.com

# Optional: full User-Agent string (overrides the default built from SEC_CONTACT_EMAIL)
# SEC_USER_AGENT=S&P500BubbleChart/1.0 (contact: you@example.com)

OUT_FILE=./data.json
CONSTITUENTS_CSV_URLS=https://datahub.io/core/s-and-p-500-companies/r/constituents.csv,https://raw.githubusercontent.com/datasets/s-and-p-500-companies/master/data/constituents.csv

# Yahoo batch size (default 40)
# YAHOO_BATCH_SIZE=40

# Delay between SEC company-facts calls in ms (default 150)
# SEC_REQUEST_DELAY_MS=150

# Optional: Supabase upload (local curl); do not commit real keys
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_BUCKET=s%26p500
# SUPABASE_OBJECT_PATH=latest/data.json
